{
  "name": "web_scrapper",
  "module": "combined-init.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --hot combined-init.ts",
    "build": "bun build combined-init.ts --outfile app.js",
    "start": "bun app.js",
    "db:push": "drizzle-kit push --force",
    "db:studio": "drizzle-kit studio",
    "queue:clear": "bun src/utils/clearQueue.ts",
    "db:clear": "bun src/utils/clearDb.ts",
    "seed": "bun seed.ts",
    "system:clear": "bun run queue:clear && bun run db:clear",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1005.0",
    "axios": "^1.13.6",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "p-limit": "5.0.0",
    "pg": "^8.20.0",
    "pg-boss": "^12.14.0",
    "turndown": "^7.2.2",
    "winston": "^3.19.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.18.0",
    "@types/turndown": "^5.0.6",
    "@types/xml2js": "^0.4.14",
    "typescript": "^5.7.3"
  }
}
