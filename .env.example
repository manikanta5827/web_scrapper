
# Environment
NODE_ENV=development
PORT=10000

# Database
DATABASE_URL=postgres://postgres:password@localhost:5432/web_scrape
QUEUE_DATABASE_URL=postgres://postgres:password@localhost:5432/web_scrape

# AWS S3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_BUCKET_NAME=your-bucket-name

# General Settings
USER_AGENT=Mozilla/5.0 (compatible; WebScraper/1.0)
HTTP_REQUEST_TIMEOUT_MS=30000
ENABLE_S3_UPLOAD=false

# Sitemap Worker Settings
SITEMAP_MIN_WORKERS=1
SITEMAP_MAX_WORKERS=5
SITEMAP_AUTOSCALE_THRESHOLD=10
SITEMAP_AUTOSCALE_INTERVAL_MS=30000
SITEMAP_JOB_BATCH_SIZE=1
SITEMAP_WORKER_POLL_INTERVAL_SECONDS=15

# Page Worker Settings
PAGE_MIN_WORKERS=1
PAGE_MAX_WORKERS=15
PAGE_AUTOSCALE_THRESHOLD=50
PAGE_AUTOSCALE_INTERVAL_MS=20000
PAGE_JOB_BATCH_SIZE=25
PAGE_WORKER_POLL_INTERVAL_SECONDS=10
PAGE_CONCURRENT_REQUESTS_LIMIT=5
PAGE_WORKER_TIMEOUT_MS=480000
PAGE_JOB_EXPIRATION_SECONDS=600

# Monitoring & Cleanup
STALLED_URL_THRESHOLD_MS=600000
STALLED_URL_CLEANUP_INTERVAL_MS=300000

# Other Limits
RETRY_LIMIT=3
RETRY_DELAY=30
MAX_HTTP_CONTENT_LENGTH=100000
DATABASE_BATCH_SIZE=500
DB_MAX_CONNECTIONS=10
BOSS_MAX_CONNECTIONS=15
DB_CONNECTION_TIMEOUT_MS=60000
DB_IDLE_TIMEOUT_MS=30000
LOG_FILE=logs/app.log
